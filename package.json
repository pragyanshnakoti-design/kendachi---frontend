{
  "name": "kendachi-backend",
  "private": true,
  "version": "1.0.0",
  "description": "Kendachi - Employee Justice & Audit Platform API",
  "main": "backend/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node backend/index.js",
    "backend": "node backend/index.js",
    "dev:backend": "nodemon backend/index.js",
    "dev:frontend": "vite --config frontend/vite.config.js",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "vite build --config frontend/vite.config.js",
    "preview": "vite preview --config frontend/vite.config.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "jsonwebtoken": "^9.0.2",
    "pg-mem": "^3.0.5",
    "pg": "^8.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "resend": "^3.2.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.4",
    "vite": "^8.0.7"
  }
}
